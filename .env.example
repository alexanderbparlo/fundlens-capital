# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — server-side only, never exposed to the client.
ANTHROPIC_API_KEY=

# ── Persistence (optional in dev) ─────────────────────────────────────────────
# Neon / Postgres connection string. Run `npm run db:migrate` after setting this.
# If absent, the tool runs fully without persistence (run snapshots are skipped,
# reload-by-URL is disabled). See lib/db/client.ts for the graceful fallback.
DATABASE_URL=

# ── Rate limiting (optional in dev) ───────────────────────────────────────────
# Upstash Redis for distributed rate limiting. Falls back to in-memory per-process
# limiting if absent (fine for local dev, not for serverless production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Public ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=FundLens Capital
NEXT_PUBLIC_APP_VERSION=0.1.0
